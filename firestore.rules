rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /articles/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /sections/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /comments/{id} {
      allow read: if resource.data.isApproved == true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
